<?xml version="1.0" encoding="UTF-8"?>

<!--
  Glossary for debookrs
-->

<glossary xml:id="glossary-main">
  <title>Glossary</title>

  <gi xml:id="gi-unknown-function">
    <title>unknown function</title>
    <p>
      In a differential equation, the unknown function is the quantity you are 
      solving for, also called the <xref ref="gi-dependent-variable" text="title"/>.
    </p>
  </gi>

  <gi xml:id="gi-antiderivative">
    <title>antiderivative</title>
    <p>
      The antiderivative of <m>f(x)</m> is a function whose derivative is <m>f(x)</m>. It is <m>y</m> in the equation <m>y' = f(x)</m>.
    </p>
  </gi>

  <gi xml:id="gi-differential-equation">
    <title>differential equation (DE)</title>
    <p>
      A differential equation is an equation involving one or more derivatives 
      of an <xref ref="gi-unknown-function" text="title"/> or 
      <xref ref="gi-dependent-variable" text="title"/>.
    </p>
  </gi>

  <gi xml:id="gi-ordinary-differential-equation">
    <title>ordinary differential equation (ODE)</title>
    <p>
      An ordinary differential equation is a differential equation whose 
      <xref ref="gi-unknown-function" text="title"/> depends on a single variable.
    </p>
  </gi>

  <gi xml:id="gi-partial-differential-equation">
    <title>partial differential equation (PDE)</title>
    <p>
      A partial differential equation is a differential equation whose 
      <xref ref="gi-unknown-function" text="title"/> depends on more than 
      one variable.
    </p>
  </gi>

  <gi xml:id="gi-dependent-variable">
    <title>dependent variable</title>
    <p>
      The dependent variable is the unknown function being solved for in a 
      <xref ref="gi-differential-equation" text="custom">DE</xref>. It is the 
      variable with derivatives applied to it.
      <md>
        -2\frac{d{\DLO y}}{dt} + 4t{\DLO\underline{y}} = t^2 \quad\text{dependent variable:}\ {\DLO\underline{y}}
      </md>
    </p>
  </gi>

  <gi xml:id="gi-independent-variable">
    <title>independent variable</title>
    <p>
      The independent variable is the variable that the 
      <xref ref="gi-dependent-variable" text="title"/> is a function of. The 
      derivatives in a <xref ref="gi-differential-equation" text="custom">DE</xref> 
      are taken with respect to the independent variable.
      <md>
        -2\frac{dy}{d{\DLO\underline{t}}} + 4{\DLO\underline{t}}y = {\DLO\underline{t}}^2 \quad\text{independent variable:}\ {\DLO\underline{t}}
      </md>
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Terms & Coefficients                                         -->
  <!-- ============================================================ -->

  <gi xml:id="gi-term">
    <title>term</title>
    <p>
      A term is any part of a <xref ref="gi-differential-equation" text="custom">DE</xref> 
      separated by addition or subtraction. Terms are identified by the 
      <xref ref="gi-dependent-variable" text="title"/> it contains. If a term 
      does not contain the dependent variable, it is called a 
      <xref ref="gi-free-term" text="title"/>.
    </p>
    <sidebyside>
      <p>
        <md>
          {\DLO\underset{y'\ \text{term}}{\underline{-2y'}}} + {\DLO\underset{y\ \text{term}}{\underline{4ty}}} = {\DLO\underset{\text{free term}}{\underline{t^2+1}}}
        </md>
      </p>
    </sidebyside>
  </gi>

  <gi xml:id="gi-free-term">
    <title>free term</title>
    <p>
      A free term is a term in a <xref ref="gi-differential-equation" text="custom">DE</xref> 
      that does not involve the <xref ref="gi-dependent-variable" text="title"/> 
      or any of its derivatives.
      <md>
        -2y' + 4ty = {\DLO\underline{t^2}} \quad\text{free term:}\ {\DLO\underline{t^2}}
      </md>
    </p>
  </gi>

  <gi xml:id="gi-coefficient">
    <title>coefficient</title>
    <p>
      A coefficient is a constant or a function of the 
      <xref ref="gi-independent-variable" text="title"/> that multiplies the 
      <xref ref="gi-dependent-variable" text="title"/> or one of its derivatives.
      <md>
        {\DLO\underline{-2}}y' + {\DLO\underline{4t}}y = t^2 \quad\text{coefficients:}\ {\DLO\underline{-2}}, {\DLO\underline{4t}}
      </md>
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Order, Linear Terms, & Linearity                             -->
  <!-- ============================================================ -->

  <gi xml:id="gi-order">
    <title>order</title>
    <p>
      The highest derivative of the 
      <xref ref="gi-dependent-variable" text="title"/> that appears 
      in a <xref ref="gi-differential-equation" text="custom">DE</xref>. 
      Powers of the variable do not affect the order.
      <md>
        <mrow>\text{3rd Order:}\quad \amp t^2y'' + {\DLO\underline{y'''}} = 0</mrow>
        <mrow>\text{2nd Order:}\quad \amp {\DLO\underline{\frac{d^2y}{dt^2}}} + 3\left(\frac{dy}{dt}\right)^4 = t</mrow>
        <mrow>\text{5th Order:}\quad \amp {\DLO\underline{y^{(5)}}} - y' + y^8 = \frac{1}{t}</mrow>
      </md>
    </p>
  </gi>

  <gi xml:id="gi-linear-term">
    <title>linear term</title>
    <p>
      A <xref ref="gi-term" text="title"/> in which the <xref ref="gi-dependent-variable" text="title"/>, <m>y</m>, or one of its derivatives appears by itself and to the first power.
      <md>
        \text{linear terms}:\quad 2ty'',\quad e^t y,\quad \frac{1}{t}y',\quad 7t 
      </md>
    </p>
  </gi>

  <gi xml:id="gi-nonlinear-term">
    <title>nonlinear term</title>
    <p>
      A <xref ref="gi-term" text="title"/> that is not linear, such as one 
      where the <xref ref="gi-dependent-variable" text="title"/> or its 
      derivatives are multiplied together, raised to a power other than one, 
      or placed inside a nonlinear function.
      <md>
        \text{nonlinear terms}:\quad y^2,\quad y\,y''',\quad \sin(y')
      </md>
    </p>
  </gi>

  <gi xml:id="gi-linear-differential-equation">
    <title>linear differential equation</title>
    <p>
      A <xref ref="gi-differential-equation" text="title"/> in which every <xref ref="gi-term" text="title"/> is a <xref ref="gi-linear-term" text="title"/>.
      <md>
        y'' + 4y' + 7y = \cos(t),\quad 
        t^2y'' - e^t y' + \frac{1}{t}y = 17t,\quad 
        y''' + \frac{1}{t}y' = 0
      </md>
    </p>
  </gi>

  <gi xml:id="gi-nonlinear-differential-equation">
    <title>nonlinear differential equation</title>
    <p>
      A <xref ref="gi-differential-equation" text="title"/> that contains at least one <xref ref="gi-nonlinear-term" text="title"/>.
      <md>
        y'' + {\DLO\underline{7y^2}} = \cos(t),\quad 
        {\DLO\underline{y''y'}} + {\DLO\underline{\frac{t}{y}}} = 17t,\quad 
        y''' + \frac{1}{t}y' = {\DLO\underline{\sin(y)}}
      </md>
    </p>
  </gi>

  <gi xml:id="gi-linear-combination">
    <title>linear combination </title>
    <p>
      A sum of <xref ref="gi-linear-term" text="custom">linear terms</xref>. For example, the equation
      <md>
        t^2y'' + 2ty' + 4y
      </md>
      is a linear combination of the <xref ref="gi-term" text="custom"><m>y''</m>, <m>y'</m>, and <m>y</m> terms</xref>.
    </p>
  </gi>

  <gi xml:id="gi-forcing-term-function">
    <title>forcing function (forcing term)</title>
    <p>
      The free term, <m>f(t)</m>, in a <xref ref="gi-linear-differential-equation" text="title"/>.
      <md>
        y'' + 4y = {\DLO\underline{\cos(t)}} \quad\text{forcing function:}\ {\DLO\underline{\cos(t)}}
      </md>
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Solutions & Initial Conditions                               -->
  <!-- ============================================================ -->

  <gi xml:id="gi-satisfies">
    <title>satisfies (a differential equation)</title>
    <p>
      A function satisfies a <xref ref="gi-differential-equation" text="custom">DE</xref> 
      when substituting the function and any needed derivatives into the equation 
      makes both sides simplify to the same expression. For example, <m>y=2x^2</m> 
      satisfies <m>xy'-2x^2=y</m> since
    </p>

    <tabular halign="center">
      <col width="20%" halign="right" right="minor"/>
      <col halign="right"/>
      <col />
      <col halign="center"/>
      <col width="20%" halign="left"/>
      <row>
        <cell>left-hand</cell>
        <cell><p><m>xy' - 2x^2</m></p></cell>
        <cell/>
        <cell/>
        <cell/>
      </row>
      <row>
        <cell>side</cell>
        <cell><p><m>x(4x) - 2x^2</m></p></cell>
        <cell/>
        <cell right="minor"><p><m>y</m></p></cell>
        <cell>right-hand</cell>
      </row>
      <row>
        <cell/>
        <cell><p><m>{\DLO 2x^2}</m></p></cell>
        <cell> <m>{\DLO \leftarrow \text{equal} \rightarrow}</m></cell>
        <cell right="minor"><p><m>{\DLO 2x^2}</m></p></cell>
        <cell>side</cell>
      </row>
    </tabular>
  </gi>

  <gi xml:id="gi-solution">
    <title>solution (to a differential equation)</title>
    <p>
      A solution to a <xref ref="gi-differential-equation" text="custom">DE</xref> 
      is a function that <xref ref="gi-satisfies" text="custom">satisfies</xref> 
      the equation. For example, since <m>y=2x^2</m> satisfies <m>xy'-2x^2=y</m>, 
      it is a solution.
    </p>
  </gi>

  <gi xml:id="gi-verifying-a-solution">
    <title>verifying (a solution to a differential equation)</title>
    <p>
      Verifying that a function, <m>y=f(x)</m>, is a solution to a 
      <xref ref="gi-differential-equation" text="custom">DE</xref> is 
      the process of showing that <m>y=f(x)</m>
      <xref ref="gi-satisfies" text="custom">satisfies</xref> the DE.
    </p>
  </gi>

  <gi xml:id="gi-general-solution">
    <title>general solution</title>
    <p>
      A general solution of a DE is the general form that all 
      <xref ref="gi-solution" text="custom">solutions</xref> share 
      up to one or more arbitrary constants. For example, 
      <m>y=ce^{2x}</m> is the general solution for <m>y'-2y=0</m>.
    </p>
  </gi>

  <gi xml:id="gi-particular-solution">
    <title>particular solution</title>
    <p>
      A particular solution is a specific function obtained from a 
      <xref ref="gi-general-solution" text="title"/> by finding or 
      selecting values for its constants. For example, if <m>y=ce^{2x}</m> 
      is a general solution, then the following are particular solutions:
    </p>
    <tabular>
      <col halign="right"/>
      <col />
      <row>
        <cell><p><m>c={\DLO -5} \to</m></p></cell>
        <cell><p><m>y={\DLO -5}e^{2x}</m></p></cell>
      </row>
      <row>
        <cell><p><m>c={\DLO 0} \to</m></p></cell>
        <cell><p><m>y={\DLO 0}</m></p></cell>
      </row>
      <row>
        <cell><p><m>c={\DLO 3} \to</m></p></cell>
        <cell><p><m>y={\DLO 3}e^{2x}</m></p></cell>
      </row>
    </tabular>
  </gi>

  <gi xml:id="gi-family-of-solutions">
    <title>family of solutions</title>
    <p>
      A family of solutions is the complete collection of all 
      <xref ref="gi-particular-solution" text="custom">particualr solutions</xref> 
      described by a <xref ref="gi-general-solution" text="title"/>. For example, 
      the family generated by <m>y=ce^{2x}</m> contains <m>y=e^{2x}</m>, 
      <m>y=3e^{2x}</m>, and infinitely many other particular solutions corresponding 
      to different values of <m>c</m>.
    </p>
  </gi>

  <gi xml:id="gi-initial-condition">
    <title>initial condition</title>
    <p>
      An initial condition is a known value of a solution or one of its derivatives 
      at a specific input value, used to determine the constants in a 
      <xref ref="gi-general-solution" text="title"/>. For example, <m>y(0)=2</m> 
      and <m>h'(0)=0</m> are initial conditions.
    </p>
  </gi>

  <gi xml:id="gi-initial-value-problem">
    <title>initial-value problem (IVP)</title>
    <p>
      An initial-value problem pairs a <xref ref="gi-differential-equation" text="custom">DE</xref> with enough 
      <xref ref="gi-initial-condition" text="custom">initial conditions</xref> 
      to determine a <xref ref="gi-particular-solution" text="title"/>. For example, 
      <md>
        h''(t)=-32,\ h(0)=100,\ h'(0)=0
      </md> 
      is an IVP because it combines a DE with initial conditions 
      at <m>t=0</m>.
    </p>
  </gi>

  <gi xml:id="gi-solution-curve">
    <title>solution curve</title>
    <p>
      A solution curve is the graph of a 
      <xref ref="gi-particular-solution" text="title"/>. In a 
      <xref ref="gi-family-of-solutions" text="custom">family</xref> such as 
      <m>y=ce^{x^2}+3</m>, each value of <m>c</m> gives a different curve, and the 
      curve through a chosen initial point is the 
      <xref ref="gi-particular-solution" text="title"/> for that 
      <xref ref="gi-initial-condition" text="title"/>.
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Direct Integration Terms                                     -->
  <!-- ============================================================ -->

  <gi xml:id="gi-constant-of-integration">
    <title>constant of integration</title>
    <p>
      A constant added when finding an antiderivative or solving a 
      <xref ref="gi-differential-equation" text="custom">DE</xref> by integration. 
      It accounts for the fact that many different functions have the same derivative. 
      For example, integrating <m>y'=2x</m> gives <m>y=x^2+c</m>, where <m>c</m> is the constant of integration.
    </p>
  </gi>

  <gi xml:id="gi-isolate-the-derivative">
    <title>isolate the derivative</title>
    <p>
      To isolate the derivative is to rewrite a 
      <xref ref="gi-differential-equation" text="custom">DE</xref> so the 
      derivative term is alone on one side of the equation. For example, 
      <m>y'+18xy=6x</m> becomes <m>y'=6x-18xy</m>.
    </p>
  </gi>

  <gi xml:id="gi-direct-integration">
    <title>direct integration</title>
    <p>
      Refers to isolating a single derivative in a 
      <xref ref="gi-differential-equation" text="custom">DE</xref> and 
      integrating both sides. For example, from
      <md>
        \frac{d}{dx}\left[e^{2x}y\right]=4e^{2x}
      </md> 
      we integrate and solve to get:
      <md>
        e^{2x}y=2e^{2x}+c \quad\Rightarrow\quad y=2+c e^{-2x}
      </md>.
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Separation of Variables                                      -->
  <!-- ============================================================ -->

  <gi xml:id="gi-separable-form">
    <title>separable form</title>
    <p>
      Separable form is the product form
      <me>
        \dfrac{dy}{dx}=f(x)\cdot g(y)
      </me>
      where one factor depends only on the independent variable and the other depends 
      only on the dependent variable. For example, 
      <md>
        \frac{dy}{dx}=x(1-y)
      </md> 
      is in separable form because the <m>x</m>-part and <m>y</m>-part appear as a product.
    </p>
  </gi>

  <gi xml:id="gi-separable">
    <title>separable (differential equation)</title>
    <p>
      A first-order <xref ref="gi-differential-equation" text="custom">DE</xref> is separable 
      if it can be rewritten in <xref ref="gi-separable-form" text="title"/>.
    </p>
  </gi>

  <gi xml:id="gi-separation-of-variables-method">
    <title>separation of variables (SOV) method</title>
    <p>
      The separation of variables method is a procedure for solving a separable 
      <xref ref="gi-differential-equation" text="custom">DE</xref> where we verify the equation 
      is separable, separate the variables onto opposite sides, integrate both sides, and solve 
      for the dependent variable if possible. For example, 
      <md>
        \frac{dy}{dx}=5x^4\cdot\frac{1}{2y} \quad\Rightarrow\quad 2y\,dy=5x^4\,dx \quad\Rightarrow\quad y^2=x^5+c
      </md>.
    </p>
  </gi>

  <gi xml:id="gi-implicit-solution">
    <title>implicit solution</title>
    <p>
      An implicit solution is a <xref ref="gi-general-solution" text="title"/> or <xref ref="gi-particular-solution" text="title"/> written as a relation involving the dependent variable, rather than with the dependent variable solved for explicitly. For example, <m>y^2=2\sin(x)+c</m> is implicit because <m>y</m> has not yet been isolated.
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Integrating Factor Terms                                     -->
  <!-- ============================================================ -->

  <gi xml:id="gi-product-rule">
    <title>product rule</title>
    <p>
      <md>
        \frac{d}{dx}[f(x)g(x)] = f(x)g'(x) + f'(x)g(x)
      </md>. 
    </p>
  </gi>

  <gi xml:id="gi-reversed-product-rule">
    <title>reversed product rule</title>
    <p>
      A reversed product rule recognizes a sum in the form 
      <md>
        f(x)g'(x)+f'(x)g(x)
      </md> 
      as the derivative <m>\frac{d}{dx}[f(x)g(x)]</m>. 
      For example, 
      <md>
        e^{2x}y' + 2e^{2x}y = \frac{d}{dx}[e^{2x}y]
      </md>.
    </p>
  </gi>

  <gi xml:id="gi-first-order-linear-differential-equation">
    <title>first-order linear differential equation</title>
    <p>
      A <xref ref="gi-order" text="custom">first-order</xref> 
      <xref ref="gi-linear-differential-equation" text="custom">linear differential equation</xref> 
      has the form:
      <md>
        A(x)y' + B(x)y = C(x)
      </md>,
      which can also be written in 
      <xref ref="gi-standard-form-first-order-linear" text="custom">standard form</xref>.
    </p>
  </gi>

  <gi xml:id="gi-standard-form-first-order-linear">
    <title>standard form (first-order linear)</title>
    <p>
      The standard form of a 
      <xref ref="gi-first-order-linear-differential-equation" text="title"/> is 
      <md>
        y' + P(x)y = Q(x)
      </md>, 
      where <m>P(x)</m> and <m>Q(x)</m> are known 
      functions of the independent variable. For example, dividing 
      <md>
        3y' = 12 - 6y
      </md> 
      by <m>3</m> and rearranging gives the standard form <m>y' + 2y = 4</m>.
    </p>
  </gi>

  <gi xml:id="gi-complete-product-rule">
    <title>complete product rule</title>
    <p>
      A complete product rule is a two-term expression that matches the pattern 
      <m>f(x)g'(x)+f'(x)g(x)</m>, so it can be grouped as a single derivative using 
      the <xref ref="gi-reversed-product-rule" text="title"/>. For example, 
      <md>
        e^{2x}y' + 2e^{2x}y
      </md> 
      is a complete product rule because it equals 
      <m>\frac{d}{dx}[e^{2x}y]</m>.
    </p>
  </gi>

  <gi xml:id="gi-integrating-factor">
    <title>integrating factor</title>
    <p>
      An integrating factor is a nonzero function multiplied onto a 
      <xref ref="gi-standard-form-first-order-linear" text="custom">standard form</xref> equation so 
      that the left-hand side becomes a <xref ref="gi-complete-product-rule" text="title"/>. 
      For <m>y' + P(x)y = Q(x)</m>, the integrating factor is 
      <md>
        \mu(x)=e^{\int P(x)\,dx}
      </md>. 
      For example, 
      <md>
        y' + 2y = 4 \quad\to\quad \mu(x) = e^{\int 2\,dx} = e^{2x}
      </md>.
    </p>
  </gi>

  <gi xml:id="gi-integrating-factor-method">
    <title>integrating factor method</title>
    <p>
      The integrating factor method solves a 
      <xref ref="gi-first-order-linear-differential-equation" text="title"/>, such as <m>3y' = 12 - 6y</m> by
    </p>
    <tabular>
      <col halign="right"/>
      <col />
      <row>
        <cell>Rewriting it in <xref ref="gi-standard-form-first-order-linear" text="custom">standard form</xref>:</cell>
        <cell><m>y' + 2y = 4</m></cell>
      </row>
      <row>
        <cell>Multiplying by an <xref ref="gi-integrating-factor" text="title"/>:</cell>
        <cell><m>e^{2x}(y' + 2y) = e^{2x}\cdot 4</m></cell>
      </row>
      <row>
        <cell><xref ref="gi-complete-product-rule" text="custom">A complete product rule</xref> on the left:</cell>
        <cell><m>[e^{2x}y]' = 4e^{2x}</m></cell>
      </row>
      <row>
        <cell><xref ref="gi-direct-integration" text="custom">Integration</xref>:</cell>
        <cell><m>e^{2x}y=2e^{2x}+c</m></cell>
      </row>
      <row>
        <cell>Solving for <m>y</m>:</cell>
        <cell><m>y=2+c e^{-2x}</m></cell>
      </row>
    </tabular>
  </gi>

</glossary>
