<?xml version="1.0" encoding="UTF-8"?>

<!--
  Glossary for debookrs
-->

<glossary xml:id="glossary-main">
  <title>Glossary</title>

  <gi xml:id="gi-unknown-function">
    <title>unknown function</title>
    <p>
      In a differential equation, the unknown function is the quantity you are solving for, also called the <xref ref="gi-dependent-variable" text="title"/>.
    </p>
  </gi>

  <gi xml:id="gi-antiderivative">
    <title>antiderivative</title>
    <p>
      The antiderivative of <m>f(x)</m> is a function whose derivative is <m>f(x)</m>. It is <m>y</m> in the equation <m>y' = f(x)</m>.
    </p>
  </gi>

  <gi xml:id="gi-differential-equation">
    <title>differential equation (DE)</title>
    <p>
      A differential equation is an equation involving one or more derivatives of an <xref ref="gi-unknown-function" text="title"/> or <xref ref="gi-dependent-variable" text="title"/>.
    </p>
  </gi>

  <gi xml:id="gi-ordinary-differential-equation">
    <title>ordinary differential equation (ODE)</title>
    <p>
      An ordinary differential equation is a differential equation whose <xref ref="gi-unknown-function" text="title"/> depends on a single variable.
    </p>
  </gi>

  <gi xml:id="gi-partial-differential-equation">
    <title>partial differential equation (PDE)</title>
    <p>
      A partial differential equation is a differential equation whose <xref ref="gi-unknown-function" text="title"/> depends on more than one variable.
    </p>
  </gi>

  <gi xml:id="gi-dependent-variable">
    <title>dependent variable</title>
    <p>
      The dependent variable is the unknown function being solved for in a differential equation. It is  the variable with derivatives applied to it.
      <md>
        -2{\DLO\underline{y}}'' + 4t{\DLO\underline{y}} = t^2 \quad\text{dependent variable:}\ {\DLO\underline{y}}
      </md>
    </p>
  </gi>

  <gi xml:id="gi-independent-variable">
    <title>independent variable</title>
    <p>
      The independent variable is the variable with respect to which the dependent variable changes and is differentiated.
      <md>
        -2y'' + 4{\DLO\underline{t}}y = {\DLO\underline{t}}^2 \quad\text{independent variable:}\ {\DLO\underline{t}}
      </md>
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Terms & Coefficients                                         -->
  <!-- ============================================================ -->

  <gi xml:id="gi-term">
    <title>term</title>
    <p>
      A term is any part of a differential equation separated by addition or subtraction. Terms are identified by the dependent variable it contains. If a term does not contain the dependent variable, it is called a <xref ref="gi-free-term" text="title"/>.
    </p>
    <sidebyside>
      <p>
        <md>
          {\DLO\underset{y''\ \text{term}}{\underline{-2y''}}} + {\DLO\underset{y\ \text{term}}{\underline{4ty}}} = {\DLO\underset{\text{free term}}{\underline{t^2+1}}}
        </md>
      </p>
    </sidebyside>
  </gi>

  <gi xml:id="gi-free-term">
    <title>free term</title>
    <p>
      A free term is a term in a differential equation that does not involve the dependent variable or any of its derivatives.
      <md>
        -2y'' + 4ty = {\DLO\underline{t^2}} \quad\text{free term:}\ {\DLO\underline{t^2}}
      </md>
    </p>
  </gi>

  <gi xml:id="gi-coefficient">
    <title>coefficient</title>
    <p>
      A coefficient is a constant or a function of the independent variable that multiplies the dependent variable or one of its derivatives.
      <md>
        {\DLO\underline{-2}}y'' + {\DLO\underline{4t}}y = t^2 \quad\text{coefficients:}\ {\DLO\underline{-2}}, {\DLO\underline{4t}}
      </md>
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Order, Linear Terms, & Linearity                             -->
  <!-- ============================================================ -->

  <gi xml:id="gi-order">
    <title>order</title>
    <p>
      The highest derivative of the dependent variable that appears in a differential equation. Powers of the variable do not affect the order. 
    </p>
    <tabular>
      <col width="30%" />
      <col width="20%" />
      <row>
        <cell><p><m>t^2y'' + y''' = 0</m></p></cell>
        <cell><p><m>\leftarrow</m> 3rd Order</p></cell>
      </row>
      <row>
        <cell><p><m>\frac{d^2y}{dt^2} + 3\left(\frac{dy}{dt}\right)^4 = t</m></p></cell>
        <cell><p><m>\leftarrow</m> 2nd Order</p></cell>
      </row>
      <row>
        <cell><p><m>y^{(5)} - y' + y^4 = \frac{1}{t}</m></p></cell>
        <cell><p><m>\leftarrow</m> 5th Order</p></cell>
      </row>
    </tabular>
  </gi>

  <gi xml:id="gi-linear-term">
    <title>linear term</title>
    <p>
      A <xref ref="gi-term" text="title"/> in which the <xref ref="gi-dependent-variable" text="title"/>, <m>y</m>, or one of its derivatives appears by itself and to the first power.
      <md>
        \text{linear terms}:\quad 2ty'',\quad e^t y,\quad \frac{1}{t}y',\quad 7t 
      </md>
    </p>
  </gi>

  <gi xml:id="gi-nonlinear-term">
    <title>nonlinear term</title>
    <p>
      A <xref ref="gi-term" text="title"/> that is not linear, such as one where the <xref ref="gi-dependent-variable" text="title"/> or its derivatives are multiplied together, raised to a power other than one, or placed inside a nonlinear function.
      <md>
        \text{nonlinear terms}:\quad y^2,\quad y\,y''',\quad \sin(y')
      </md>
    </p>
  </gi>

  <gi xml:id="gi-linear-differential-equation">
    <title>linear differential equation</title>
    <p>
      A <xref ref="gi-differential-equation" text="title"/> in which every <xref ref="gi-term" text="title"/> is a <xref ref="gi-linear-term" text="title"/>.
      <md>
        y'' + 4y' + 7y = \cos(t),\quad 
        t^2y'' - e^t y' + \frac{1}{t}y = 17t,\quad 
        y''' + \frac{1}{t}y' = 0
      </md>
    </p>
  </gi>

  <gi xml:id="gi-nonlinear-differential-equation">
    <title>nonlinear differential equation</title>
    <p>
      A <xref ref="gi-differential-equation" text="title"/> that contains at least one <xref ref="gi-nonlinear-term" text="title"/>.
      <md>
        y'' + {\DLO\underline{7y^2}} = \cos(t),\quad 
        {\DLO\underline{y''y'}} + {\DLO\underline{\frac{t}{y}}} = 17t,\quad 
        y''' + \frac{1}{t}y' = {\DLO\underline{\sin(y)}}
      </md>
    </p>
  </gi>

  <gi xml:id="gi-linear-combination">
    <title>linear combination </title>
    <p>
      A sum of <xref ref="gi-linear-term" text="custom">linear terms</xref>. For example, the equation
      <md>
        t^2y'' + 2ty' + 4y
      </md>
      is a linear combination of the <xref ref="gi-term" text="custom"><m>y''</m>, <m>y'</m>, and <m>y</m> terms</xref>.
    </p>
  </gi>

  <gi xml:id="gi-forcing-term-function">
    <title>forcing function (forcing term)</title>
    <p>
      The free term, <m>f(t)</m>, in a <xref ref="gi-linear-differential-equation" text="title"/>.
      <md>
        y'' + 4y = {\DLO\underline{\cos(t)}} \quad\text{forcing function:}\ {\DLO\underline{\cos(t)}}
      </md>
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Solutions & Initial Conditions                               -->
  <!-- ============================================================ -->

  <gi xml:id="gi-satisfies-a-differential-equation">
    <title>satisfies a differential equation</title>
    <p>
      A function satisfies a <xref ref="gi-differential-equation" text="title"/> when substituting the function and any needed derivatives into the equation makes both sides simplify to the same expression. For example, <m>y=e^{3x}</m> satisfies <m>y'=3y</m> because both sides simplify to <m>3e^{3x}</m>.
    </p>
  </gi>

  <gi xml:id="gi-solution-to-a-differential-equation">
    <title>solution to a differential equation</title>
    <p>
      A solution to a <xref ref="gi-differential-equation" text="title"/> is a function that satisfies the equation. For example, <m>y=2x^2</m> is a solution of <m>xy'-2x^2=y</m> because substitution makes both sides equal <m>2x^2</m>.
    </p>
  </gi>

  <gi xml:id="gi-verifying-a-solution">
    <title>verifying a solution</title>
    <p>
      Verifying a solution means computing any needed derivatives, substituting into the differential equation, and simplifying to check that both sides agree. For example, if substitution leads to <m>2x^2=2x^2</m>, then the function has been verified as a solution.
    </p>
  </gi>

  <gi xml:id="gi-general-solution">
    <title>general solution</title>
    <p>
      A general solution is a formula that represents a family of particular solutions to a differential equation by including one or more arbitrary constants. For example, <m>y=ce^{2x}</m> is the general solution presented for <m>y'-2y=0</m>, and different values of <m>c</m> produce different particular solutions.
    </p>
  </gi>

  <gi xml:id="gi-particular-solution">
    <title>particular solution</title>
    <p>
      A particular solution is a specific function obtained from a general solution after choosing values for its constants. For example, choosing <m>c=-5</m> in <m>y=ce^{2x}</m> gives the particular solution <m>y=-5e^{2x}</m>.
    </p>
  </gi>

  <gi xml:id="gi-family-of-solutions">
    <title>family of solutions</title>
    <p>
      A family of solutions is the complete collection of all particular solutions described by a general solution. For example, the family generated by <m>y=ce^{2x}</m> contains <m>y=e^{2x}</m>, <m>y=3e^{2x}</m>, and infinitely many other choices of <m>c</m>.
    </p>
  </gi>

  <gi xml:id="gi-initial-condition">
    <title>initial condition</title>
    <p>
      An initial condition is a known value of a solution or one of its derivatives at a specific input value, used to determine the constants in a general solution. For example, <m>y(0)=2</m> and <m>h'(0)=0</m> are initial conditions.
    </p>
  </gi>

  <gi xml:id="gi-initial-value-problem">
    <title>initial-value problem (IVP)</title>
    <p>
      An initial-value problem pairs a differential equation with enough initial conditions to determine a particular solution. For example, <m>h''(t)=-32,\ h(0)=100,\ h'(0)=0</m> is an IVP because it combines a differential equation with initial conditions for the falling object.
    </p>
  </gi>

  <gi xml:id="gi-solution-curve">
    <title>solution curve</title>
    <p>
      A solution curve is the graph of a particular solution. In a family such as <m>y=ce^{x^2}+3</m>, each value of <m>c</m> gives a different curve, and the curve through a chosen initial point is the particular solution for that initial condition.
    </p>
  </gi>

</glossary>
