<?xml version="1.0" encoding="UTF-8"?>

<!--
  Glossary for debookrs
-->

<glossary xml:id="glossary-main">
  <title>Glossary</title>

  <!-- ============================================================ -->
  <!-- Order Terms                                                   -->
  <!-- ============================================================ -->

  <gi xml:id="gi-order">
    <title>Order</title>
    <p>
      The highest derivative of the dependent variable that appears in a differential equation. Powers of the variable do not affect the order.
    </p>
    <p>
      Example: <m>y'' + 3y' = t</m> is second-order, while <m>t^2y'' + y''' = 0</m> is third-order.
    </p>
    <p>
      Visual cue: scan for the highest prime mark or derivative notation that appears anywhere in the equation.
  <!-- Connection to Algebra & Calculus Terms                       -->
  <!-- ============================================================ -->

  <gi xml:id="gi-unknown-function">
    <title>unknown function</title>
    <p>
      In a differential equation, the unknown function is the quantity you are solving for, just as an unknown variable is the quantity you solve for in algebra.
    </p>
  </gi>

  <gi xml:id="gi-antiderivative">
    <title>antiderivative</title>
    <p>
      An antiderivative is a function whose derivative matches a given expression, so finding one solves equations of the form <m>y' = f(x)</m>.
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Linear &amp; Nonlinear Terms                                    -->
  <!-- ============================================================ -->

  <gi xml:id="gi-linear-term">
    <title>Linear Term</title>
    <p>
      A term in which the dependent variable or one of its derivatives appears by itself and to the first power, multiplied only by a coefficient that depends on the independent variable.
    </p>
    <p>
      Example: <m>2t\,y''</m> and <m>e^t y</m> are linear terms.
    </p>
    <p>
      Visual cue: each term contains just one copy of <m>y</m> or one derivative, not a product like <m>y\,y'</m> and not a power like <m>y^2</m>.
    </p>
  </gi>

  <gi xml:id="gi-nonlinear-term">
    <title>Nonlinear Term</title>
    <p>
      A term that is not linear, such as one where the dependent variable or its derivatives are multiplied together, raised to a power other than one, or placed inside a nonlinear function.
    </p>
    <p>
      Example: <m>y^2</m>, <m>y\,y'''</m>, and <m>\sin(y')</m> are nonlinear terms.
    </p>
    <p>
      Visual cue: a square, product, or nonlinear function wrapped around <m>y</m> or a derivative signals nonlinearity.
  <!-- Differential Equation Definition Terms                       -->
  <!-- ============================================================ -->

  <gi xml:id="gi-differential-equation">
    <title>differential equation (DE)</title>
    <p>
      A differential equation is an equation involving one or more derivatives of an unknown function.
    </p>
  </gi>

  <gi xml:id="gi-ordinary-differential-equation">
    <title>ordinary differential equation (ODE)</title>
    <p>
      An ordinary differential equation is a differential equation whose unknown function depends on a single variable.
    </p>
  </gi>

  <gi xml:id="gi-partial-differential-equation">
    <title>partial differential equation (PDE)</title>
    <p>
      A partial differential equation is a differential equation whose unknown function depends on more than one variable.
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Linearity Terms                                               -->
  <!-- ============================================================ -->

  <gi xml:id="gi-linear-differential-equation">
    <title>Linear Differential Equation</title>
    <p>
      A differential equation in which every term involving the dependent variable and its derivatives is linear.
    </p>
    <p>
      Example: <m>y'' + \frac{1}{t}y' + y = 17t</m> is linear because each term involving <m>y</m> is linear.
    </p>
    <p>
      Visual cue: the equation can be arranged as coefficient functions multiplying <m>y</m>, <m>y'</m>, <m>y''</m>, and so on, with no products or powers of those terms.
    </p>
  </gi>

  <gi xml:id="gi-nonlinear-differential-equation">
    <title>Nonlinear Differential Equation</title>
    <p>
      A differential equation that contains at least one nonlinear term.
    </p>
    <p>
      Example: <m>y'' + y^2 = 17t</m> is nonlinear because the term <m>y^2</m> is nonlinear.
    </p>
    <p>
      Visual cue: one nonlinear term anywhere in the equation makes the entire differential equation nonlinear.
    </p>
  </gi>

  <gi xml:id="gi-linear-combination">
    <title>Linear Combination</title>
    <p>
      A sum of <xref ref="gi-linear-term" text="custom">linear terms</xref> formed by multiplying the dependent variable or its derivatives by coefficients that depend only on the independent variable.
    </p>
    <p>
      Example: <m>a_2(t)y'' + a_1(t)y' + a_0(t)y</m> is a linear combination where each term is linear.
    </p>
    <p>
      Visual cue: think of the expression as a column of matching derivative terms, each paired with its own coefficient function.
    </p>
  </gi>

  <gi xml:id="gi-forcing-term">
    <title>Forcing Term</title>
    <p>
      The input term <m>f(t)</m> in a linear differential equation, which depends only on the independent variable and not on the dependent variable or its derivatives.
    </p>
    <p>
      Example: in <m>y'' + 4y = \cos(t)</m>, the forcing term is <m>\cos(t)</m>.
    </p>
    <p>
      Visual cue: it is the term that remains after all of the <m>y</m>-terms are grouped together, and it contains no <m>y</m> at all.
  <!-- Dependent & Independent Variables Terms                      -->
  <!-- ============================================================ -->

  <gi xml:id="gi-dependent-variable">
    <title>dependent variable</title>
    <p>
      The dependent variable is the unknown function in a differential equation; it changes in response to the independent variable and is the quantity being solved for.
    </p>
  </gi>

  <gi xml:id="gi-independent-variable">
    <title>independent variable</title>
    <p>
      The independent variable is the variable with respect to which the dependent variable changes and is differentiated.
    </p>
  </gi>

  <!-- ============================================================ -->
  <!-- Terms & Coefficients Terms                                   -->
  <!-- ============================================================ -->

  <gi xml:id="gi-term">
    <title>term</title>
    <p>
      A term is any part of a differential equation separated from other parts by addition or subtraction.
    </p>
  </gi>

  <gi xml:id="gi-free-term">
    <title>free term</title>
    <p>
      A free term is a term in a differential equation that does not involve the dependent variable or any of its derivatives.
    </p>
  </gi>

  <gi xml:id="gi-coefficient">
    <title>coefficient</title>
    <p>
      A coefficient is a constant or a function of the independent variable that multiplies the dependent variable or one of its derivatives.
    </p>
  </gi>

</glossary>
